# LLM_MODE: DETERMINISTIC (sin OpenAI, default seguro para dev/tests) | OPENAI (produccion: el bot redacta).
LLM_MODE=DETERMINISTIC
OPENAI_API_KEY=
OPENAI_UNDERSTANDING_MODEL=gpt-5.4-mini
OPENAI_WRITING_MODEL=gpt-5.4-mini
# Timeouts ajustados al techo real de ~10s de Vercel Hobby (2 llamadas OpenAI por turno x reintentos deben
# caber). NO subir en Hobby: 12000/1 podia matar la lambda a mitad de turno y perder la respuesta.
OPENAI_TIMEOUT_MS=4000
OPENAI_MAX_RETRIES=0
AUTOMATION_MODE=HUMAN_APPROVAL
AB_MODEL_A=gpt-5.4-nano
AB_MODEL_B=gpt-5.4-mini
DATABASE_URL=
# Persistencia del simulador: postgres (PostgreSQL vía DATABASE_URL) | json (snapshot en data/, default) | memory (volátil)
PERSISTENCE=json
# Candado de contraseña para TODA la web (CRM, datos de candidatas y el disparador de llamada con coste).
# OPT-IN: si se deja vacio, la web queda abierta (sin cambio). Si pones una contraseña, el navegador la pide
# (usuario cualquiera + esta contraseña). NO afecta a los endpoints de maquina (ElevenLabs/Meta). Valor real
# SOLO en .env.local / Vercel. Recomendado en produccion. Ej: una frase larga.
SITE_PASSWORD=
# --- Instagram (Messenger Platform). Los valores reales SOLO en .env.local, nunca aquí. ---
# Token que tú eliges para el handshake del webhook (el mismo en Meta y aquí).
INSTAGRAM_VERIFY_TOKEN=
# App secret de tu app de Meta (verifica la firma de cada webhook).
INSTAGRAM_APP_SECRET=
# Token de acceso (Instagram/Page) para enviar DMs por la Graph API.
INSTAGRAM_ACCESS_TOKEN=
# Base de la Graph API: graph.instagram.com (Instagram login) o graph.facebook.com (Facebook login).
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_VERSION=v21.0
# --- Avisos al operador por WhatsApp (CallMeBot, gratis). Valores reales SOLO en .env.local. ---
# Setup (2 min): 1) agenda el numero +34 644 51 95 23 (CallMeBot) en tu telefono. 2) mandale por WhatsApp
# el texto: "I allow callmebot to send me messages". 3) te responde con tu apikey personal. Pega aqui tu
# numero (con prefijo, p.ej. +34600111222) y la apikey. Si se dejan vacios, no se envian avisos (no-op).
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
# --- Deteccion de cuenta privada/publica via proveedor de terceros (Apify). Valor real SOLO en
# .env.local. El proveedor scrapea con SU infra (riesgo de baneo en ellos, no en tus cuentas). Registrate
# en apify.com (free plan: 5$/mes de credito, sin tarjeta ni minimo), Settings -> Integrations -> API
# token. Sin token, el CRM no muestra privada/publica (no-op). ---
APIFY_TOKEN=
# Actor opcional (por defecto el oficial apify~instagram-profile-scraper).
APIFY_ACTOR=
# --- Cron de RE-ENGANCHE (recuperar candidatas que dejan de contestar). Valor real SOLO en .env.local. ---
# Secreto del cron de re-enganche: inventa un token largo y aleatorio. En Vercel ponlo IGUAL (Settings ->
# Environment Variables) y Vercel Cron lo manda como bearer (Authorization: Bearer <CRON_SECRET>). Sin el,
# el endpoint /api/cron/outreach responde 503 (no-op). Ej: openssl rand -hex 32
CRON_SECRET=
# --- Bot de LLAMADA (voz). Valores reales SOLO en .env.local. ---
# Secreto bearer que protege el endpoint Custom LLM (/api/call/llm) que llamara ElevenLabs. Inventa un
# token largo y aleatorio y ponlo TAMBIEN en la config del agente de ElevenLabs. Sin el, el endpoint
# responde 503. Ej: openssl rand -hex 32
CALL_LLM_API_KEY=
# Secreto bearer del webhook de fin de llamada (/api/call/end). Otro token aleatorio distinto.
CALL_WEBHOOK_SECRET=
# ¿La APERTURA anuncia que se graba la llamada? 0 o vacio = NO lo anuncia (default, decision de Alex jul-2026).
# 1 = SI lo anuncia (opt-in). Independiente de la grabacion real: el audio se guarda en ElevenLabs (Audio
# Saving) se ponga lo que se ponga aqui; esto solo controla si el bot LO MENCIONA en el saludo.
CALL_RECORDED=0
# ¿Suena la APERTURA/saludo de la llamada ("Hola, soy Alex de Rose Models... ¿te cuento como trabajamos?")?
# on por defecto (recomendado: el bot saluda antes de nada). =off SOLO para pruebas (arrancaria directo con
# el pitch, sin saludo).
CALL_DISCLOSURE=on
# Redaccion NATURAL por IA en la llamada (usa OPENAI_API_KEY). off por defecto (guion determinista). =on
# para que el LLM redacte (pasa por el validador de voz + fallback). Enciendelo y afinalo escuchando.
CALL_LLM_REDACTION=off
# Disparador de la llamada saliente por TELEFONO (SIP/Zadarma, via ElevenLabs Agents).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Id del numero de telefono importado en ElevenLabs (Agents > Phone numbers > Import from SIP trunk).
# ElevenLabs lo devuelve al importar el numero de Zadarma. Las credenciales SIP NO van aqui (las guarda ElevenLabs).
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# --- Bandeja de WhatsApp (Cloud API de Meta) para ver/responder los chats del numero de la agencia.
# Valores reales SOLO en .env.local. Guia: WHATSAPP_SETUP.md. Si falta algo, la integracion queda
# desactivada (no procesa) — no rompe nada. La base SIEMPRE es graph.facebook.com (la pone el codigo). ---
# Token que TU eliges para el handshake del webhook (GET hub.verify_token). Inventa una palabra secreta.
WHATSAPP_VERIFY_TOKEN=
# App Secret de la app de Meta (para verificar la firma X-Hub-Signature-256). OPCIONAL: si Instagram y
# WhatsApp estan en la MISMA app de Meta, se reutiliza INSTAGRAM_APP_SECRET / _ALT (no hace falta ponerlo).
WHATSAPP_APP_SECRET=
# Token PERMANENTE de System User con permisos whatsapp_business_messaging + whatsapp_business_management.
WHATSAPP_ACCESS_TOKEN=
# Id del numero de telefono de WhatsApp (panel de Meta o ElevenLabs > Copy phone number ID).
WHATSAPP_PHONE_NUMBER_ID=
# Version de la Graph API (opcional, default v21.0).
WHATSAPP_GRAPH_VERSION=v21.0
# --- DEBOUNCE de mensajes entrantes (cola QStash): esperar a que la candidata termine de escribir y
# responder a toda su rafaga de una vez (mas humano). Valores reales SOLO en .env.local / Vercel. ---
# Token + URL de QStash (Upstash) para PUBLICAR la llamada de vuelta diferida. El callback se autentica con
# CRON_SECRET reenviado (no hace falta verificar la firma de QStash). Si falta el token, el debounce no se usa.
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
# Signing keys de QStash (reservadas por si se anade verificacion de firma; hoy no se usan, el callback va
# autenticado con CRON_SECRET). Ponlas igual, no molestan.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Interruptor de ACTIVACION del debounce. off por defecto (el bot responde al instante, como siempre).
# Ponlo =on SOLO cuando quieras activar la espera (tras probar). Ventana ajustable con INBOUND_DEBOUNCE_MS.
INBOUND_DEBOUNCE=off
# Ventana de espera tras el ultimo mensaje de la candidata, en ms (default 55000 = 55s).
INBOUND_DEBOUNCE_MS=55000
