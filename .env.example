LLM_MODE=DETERMINISTIC
OPENAI_API_KEY=
OPENAI_UNDERSTANDING_MODEL=gpt-5.4-mini
OPENAI_WRITING_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=12000
OPENAI_MAX_RETRIES=1
AUTOMATION_MODE=HUMAN_APPROVAL
AB_MODEL_A=gpt-5.4-nano
AB_MODEL_B=gpt-5.4-mini
DATABASE_URL=
# Persistencia del simulador: postgres (PostgreSQL vía DATABASE_URL) | json (snapshot en data/, default) | memory (volátil)
PERSISTENCE=json
# Candado de contraseña para TODA la web (CRM, datos de candidatas y el disparador de llamada con coste).
# OPT-IN: si se deja vacio, la web queda abierta (sin cambio). Si pones una contraseña, el navegador la pide
# (usuario cualquiera + esta contraseña). NO afecta a los endpoints de maquina (ElevenLabs/Meta). Valor real
# SOLO en .env.local / Vercel. Recomendado en produccion. Ej: una frase larga.
SITE_PASSWORD=
# --- Instagram (Messenger Platform). Los valores reales SOLO en .env.local, nunca aquí. ---
# Token que tú eliges para el handshake del webhook (el mismo en Meta y aquí).
INSTAGRAM_VERIFY_TOKEN=
# App secret de tu app de Meta (verifica la firma de cada webhook).
INSTAGRAM_APP_SECRET=
# Token de acceso (Instagram/Page) para enviar DMs por la Graph API.
INSTAGRAM_ACCESS_TOKEN=
# Base de la Graph API: graph.instagram.com (Instagram login) o graph.facebook.com (Facebook login).
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_VERSION=v21.0
# --- Avisos al operador por WhatsApp (CallMeBot, gratis). Valores reales SOLO en .env.local. ---
# Setup (2 min): 1) agenda el numero +34 644 51 95 23 (CallMeBot) en tu telefono. 2) mandale por WhatsApp
# el texto: "I allow callmebot to send me messages". 3) te responde con tu apikey personal. Pega aqui tu
# numero (con prefijo, p.ej. +34600111222) y la apikey. Si se dejan vacios, no se envian avisos (no-op).
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
# --- Deteccion de cuenta privada/publica via proveedor de terceros (Apify). Valor real SOLO en
# .env.local. El proveedor scrapea con SU infra (riesgo de baneo en ellos, no en tus cuentas). Registrate
# en apify.com (free plan: 5$/mes de credito, sin tarjeta ni minimo), Settings -> Integrations -> API
# token. Sin token, el CRM no muestra privada/publica (no-op). ---
APIFY_TOKEN=
# Actor opcional (por defecto el oficial apify~instagram-profile-scraper).
APIFY_ACTOR=
# --- Bot de LLAMADA (voz). Valores reales SOLO en .env.local. ---
# Secreto bearer que protege el endpoint Custom LLM (/api/call/llm) que llamara ElevenLabs. Inventa un
# token largo y aleatorio y ponlo TAMBIEN en la config del agente de ElevenLabs. Sin el, el endpoint
# responde 503. Ej: openssl rand -hex 32
CALL_LLM_API_KEY=
# Secreto bearer del webhook de fin de llamada (/api/call/end). Otro token aleatorio distinto.
CALL_WEBHOOK_SECRET=
# La llamada se graba/transcribe (1) o no (0). Si es 1, la apertura legal avisa de la grabacion. Default 1.
CALL_RECORDED=1
# Apertura legal de la llamada (IA + grabacion). on por defecto; =off SOLO para pruebas (OBLIGATORIA por
# ley antes de llamar a una candidata real, volver a quitarla/on).
CALL_DISCLOSURE=on
# Redaccion NATURAL por IA en la llamada (usa OPENAI_API_KEY). off por defecto (guion determinista). =on
# para que el LLM redacte (pasa por el validador de voz + fallback). Enciendelo y afinalo escuchando.
CALL_LLM_REDACTION=off
# Disparador de la llamada saliente por WhatsApp (ElevenLabs Agents).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Id del numero de WhatsApp Business conectado en ElevenLabs (panel de ElevenLabs > WhatsApp).
ELEVENLABS_WHATSAPP_PHONE_NUMBER_ID=
# Nombre + idioma de la plantilla de "solicitud de permiso de llamada" creada en WhatsApp Manager.
ELEVENLABS_CALL_PERMISSION_TEMPLATE=
ELEVENLABS_CALL_PERMISSION_TEMPLATE_LANG=es
