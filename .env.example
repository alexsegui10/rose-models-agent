LLM_MODE=DETERMINISTIC
OPENAI_API_KEY=
OPENAI_UNDERSTANDING_MODEL=gpt-5.4-mini
OPENAI_WRITING_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=12000
OPENAI_MAX_RETRIES=1
AUTOMATION_MODE=HUMAN_APPROVAL
AB_MODEL_A=gpt-5.4-nano
AB_MODEL_B=gpt-5.4-mini
DATABASE_URL=
# Persistencia del simulador: postgres (PostgreSQL vía DATABASE_URL) | json (snapshot en data/, default) | memory (volátil)
PERSISTENCE=json
# --- Instagram (Messenger Platform). Los valores reales SOLO en .env.local, nunca aquí. ---
# Token que tú eliges para el handshake del webhook (el mismo en Meta y aquí).
INSTAGRAM_VERIFY_TOKEN=
# App secret de tu app de Meta (verifica la firma de cada webhook).
INSTAGRAM_APP_SECRET=
# Token de acceso (Instagram/Page) para enviar DMs por la Graph API.
INSTAGRAM_ACCESS_TOKEN=
# Base de la Graph API: graph.instagram.com (Instagram login) o graph.facebook.com (Facebook login).
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_VERSION=v21.0
